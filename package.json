{
  "name": "minecraft-bot",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts --",
    "start": "bun run src/index.ts --",
    "check-types": "tsc --noEmit",
    "tests": "bun run tests/test-connection.ts",
    "build": "bun build --compile src/index.ts --outfile dist/minecraft-bot",
    "build:win": "bun build --compile --target=bun-windows-x64 src/index.ts --outfile dist/minecraft-bot.exe",
    "build:linux": "bun build --compile --target=bun-linux-x64 src/index.ts --outfile dist/minecraft-bot"
  },
  "dependencies": {
    "ai": "^6.0.6",
    "gambi-sdk": "^0.3.0",
    "jsonrepair": "^3.12.0",
    "mineflayer": "^4.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
