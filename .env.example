# ─── Gambiarra Hub ─────────────────────────────────────────
# URL do hub Gambiarra (defaults para CLI --hub e env fallback)
GAMBIARRA_HUB_URL=http://localhost:3000

# Modelo preferido (default para CLI --model, "*" usa qualquer)
GAMBIARRA_MODEL=*

# Nota: o room code é passado via CLI, não aqui.
#   bun run dev --room ABC123

# ─── Servidor Minecraft ───────────────────────────────────
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
BOT_USERNAME=AgenteBot
BOT_AUTH=offline
