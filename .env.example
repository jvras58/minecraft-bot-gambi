# ─── Gambiarra Hub ─────────────────────────────────────────
# URL do hub Gambiarra (defaults para CLI --hub e env fallback)
GAMBIARRA_HUB_URL=http://localhost:3000

# Modelo preferido (default para CLI --model, "*" usa qualquer)
GAMBIARRA_MODEL=*

# Nota: o room code é passado via CLI, não aqui.
#   bun run dev --room ABC123

# ─── Servidor Minecraft ───────────────────────────────────
MINECRAFT_HOST=localhost
MINECRAFT_PORT=25565
BOT_USERNAME=AgenteBot
BOT_AUTH=offline

# ─── Coleta de Métricas (opcional) ────────────────────────
# Configure para enviar dados de cada ciclo para Supabase.
# Se não configurar, o bot funciona normalmente sem coletar dados.
#
# 1. Crie um projeto em https://supabase.com
# 2. Execute o SQL de supabase/schema.sql no SQL Editor
# 3. Copie a URL e anon key das Settings > API
# SUPABASE_URL=https://SEU-PROJETO.supabase.co
# SUPABASE_ANON_KEY=eyJ...sua-anon-key-aqui
# SUPABASE_TABLE=bot_cycles
